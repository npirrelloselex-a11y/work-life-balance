<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Work–Life Balance Quiz</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: Georgia, serif;
      background: #f5f0eb;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      padding: 20px;
    }

    .card {
      background: #faf7f3;
      border: 1px solid #ddd;
      max-width: 560px;
      width: 100%;
      padding: 32px 36px;
      border-radius: 4px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.08);
    }

    h1 {
      font-family: Arial, sans-serif;
      font-size: 15px;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      color: #c0392b;
      text-align: center;
      margin-bottom: 16px;
    }

    .instructions {
      font-style: italic;
      font-size: 13.5px;
      color: #444;
      margin-bottom: 20px;
      border-bottom: 1px solid #ccc;
      padding-bottom: 14px;
      line-height: 1.6;
    }

    .question {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      margin-bottom: 14px;
      font-size: 14px;
      color: #222;
      line-height: 1.6;
    }

    .question span.num {
      min-width: 16px;
      font-weight: bold;
      color: #444;
    }

    .question label {
      flex: 1;
    }

    .question label b {
      font-weight: 700;
    }

    .question select {
      margin-left: 8px;
      padding: 2px 6px;
      font-size: 14px;
      border: 1px solid #aaa;
      border-radius: 3px;
      background: white;
      cursor: pointer;
    }

    .divider {
      border: none;
      border-top: 1px solid #ccc;
      margin: 22px 0 16px;
    }

    .add-up {
      font-style: italic;
      font-size: 13.5px;
      color: #444;
      margin-bottom: 16px;
      line-height: 1.6;
    }

    button {
      display: block;
      margin: 0 auto 20px;
      background: #c0392b;
      color: white;
      border: none;
      padding: 10px 28px;
      font-size: 14px;
      border-radius: 3px;
      cursor: pointer;
      font-family: Arial, sans-serif;
      letter-spacing: 0.5px;
    }

    button:hover { background: #a93226; }

    .result {
      display: none;
      padding: 14px 16px;
      border-radius: 4px;
      font-size: 14px;
      line-height: 1.6;
      font-family: Arial, sans-serif;
    }

    .result .score-line {
      font-weight: bold;
      font-size: 15px;
      margin-bottom: 6px;
    }

    .result.red    { background: #fdecea; border-left: 4px solid #c0392b; color: #7b1c14; }
    .result.yellow { background: #fef9e7; border-left: 4px solid #e6a817; color: #7d5a00; }
    .result.green  { background: #eafaf1; border-left: 4px solid #27ae60; color: #1a6b3c; }

    .range { font-weight: bold; }
  </style>
</head>
<body>
  <div class="card">
    <h1>Find Out Your Work–Life Balance</h1>

    <p class="instructions">
      Write <strong>2</strong> if the statement is true for you, <strong>1</strong> if it's mostly true and <strong>0</strong> if it's not true.
    </p>

    <div class="question">
      <span class="num">1</span>
      <label>I <b>enjoy doing</b> exercise and <b>playing</b> sport.
        <select id="q1">
          <option value="" disabled selected>—</option>
          <option value="2">2</option>
          <option value="1">1</option>
          <option value="0">0</option>
        </select>
      </label>
    </div>

    <div class="question">
      <span class="num">2</span>
      <label>I never think <b>about checking</b> work emails in my free time.
        <select id="q2">
          <option value="" disabled selected>—</option>
          <option value="2">2</option>
          <option value="1">1</option>
          <option value="0">0</option>
        </select>
      </label>
    </div>

    <div class="question">
      <span class="num">3</span>
      <label>This year, I <b>intend to take</b> all my annual leave.
        <select id="q3">
          <option value="" disabled selected>—</option>
          <option value="2">2</option>
          <option value="1">1</option>
          <option value="0">0</option>
        </select>
      </label>
    </div>

    <div class="question">
      <span class="num">4</span>
      <label>I always leave work on time <b>to make sure</b> I have free time in the evening.
        <select id="q4">
          <option value="" disabled selected>—</option>
          <option value="2">2</option>
          <option value="1">1</option>
          <option value="0">0</option>
        </select>
      </label>
    </div>

    <div class="question">
      <span class="num">5</span>
      <label>I think it's <b>important to take</b> an hour for lunch.
        <select id="q5">
          <option value="" disabled selected>—</option>
          <option value="2">2</option>
          <option value="1">1</option>
          <option value="0">0</option>
        </select>
      </label>
    </div>

    <hr class="divider"/>

    <p class="add-up">Now add up your score and find out what it means:</p>

    <button onclick="calcScore()">Check my score</button>

    <div class="result red" id="result-low">
      <div class="score-line">Your score: <span id="score-low"></span> / 10</div>
      <span class="range">0–4</span> Your life is out of balance. Put less emphasis on your job and give more time to family, friends and leisure.
    </div>

    <div class="result yellow" id="result-mid">
      <div class="score-line">Your score: <span id="score-mid"></span> / 10</div>
      <span class="range">5–8</span> Your work–life balance is OK, but be careful. You need to spend more time relaxing.
    </div>

    <div class="result green" id="result-high">
      <div class="score-line">Your score: <span id="score-high"></span> / 10</div>
      <span class="range">9–10</span> You have a great work–life balance. Don't change it!
    </div>
  </div>

  <script>
    function calcScore() {
      const ids = ['q1','q2','q3','q4','q5'];
      let total = 0;
      let allAnswered = true;

      for (const id of ids) {
        const val = document.getElementById(id).value;
        if (val === '') { allAnswered = false; break; }
        total += parseInt(val);
      }

      if (!allAnswered) {
        alert('Please answer all questions before checking your score.');
        return;
      }

      document.getElementById('result-low').style.display  = 'none';
      document.getElementById('result-mid').style.display  = 'none';
      document.getElementById('result-high').style.display = 'none';

      if (total <= 4) {
        document.getElementById('score-low').textContent = total;
        document.getElementById('result-low').style.display = 'block';
      } else if (total <= 8) {
        document.getElementById('score-mid').textContent = total;
        document.getElementById('result-mid').style.display = 'block';
      } else {
        document.getElementById('score-high').textContent = total;
        document.getElementById('result-high').style.display = 'block';
      }
    }
  </script>
</body>
</html>
